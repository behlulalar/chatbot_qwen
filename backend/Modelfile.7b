# Qwen2.5:7B için SUBU Mevzuat Asistanı - hafif, hızlı
# Kullanım: ollama create subu-qwen-7b -f Modelfile.7b
# .env: MODEL_NAME=subu-qwen-7b
# Veya direkt: MODEL_NAME=qwen2.5:7b

FROM qwen2.5:7b
PARAMETER temperature 0.1
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.1
PARAMETER num_ctx 8192
PARAMETER top_k 40
