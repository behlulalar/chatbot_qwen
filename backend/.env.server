# Sunucu şablonu (10.80.0.175) — ilk çalıştırmada: cp .env.server .env ve aşağıdaki iki değeri doldur

# ZORUNLU: Sunucudaki PostgreSQL bilgilerinizi girin
DATABASE_URL=postgresql://subu_user:SIFRE_BURAYA@localhost:5432/subu_chatbot

# ZORUNLU: Embedding için (ChromaDB) — OpenAI key
OPENAI_API_KEY=sk-buraya-openai-key-yapistir

# Uygulama
PORT=8000
APP_NAME=SUBU Mevzuat Chatbot
APP_VERSION=1.0.0
DEBUG=False

# ChromaDB (sunucuda mutlak path önerilir: /home/behlulalar/behlul/backend/data/chroma_db)
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
DOWNLOAD_DIRECTORY=./data/raw_pdfs
ARCHIVE_DIRECTORY=./data/archive
JSON_DIRECTORY=./data/processed_json

# LLM: Qwen 14B (Ollama) — sunucuda ollama pull qwen2.5:14b
LLM_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen2.5:14b
TEMPERATURE=0.1
MAX_TOKENS=2000

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# CORS — 10.80.0.175 üzerinden erişim
CORS_ORIGINS=http://10.80.0.175:3000,http://10.80.0.175:3001,http://10.80.0.175:80,http://10.80.0.175,http://localhost:3000,http://localhost:3001,http://localhost:80

# Cache
REDIS_ENABLED=False
REDIS_HOST=localhost
REDIS_PORT=6379
QUERY_CACHE_TTL=3600
RESPONSE_CACHE_TTL=1800

# Scraper
QDMS_URL=https://hukuk.subu.edu.tr/yonergeler
UPDATE_INTERVAL=24
