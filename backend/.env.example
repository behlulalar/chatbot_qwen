# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/subu_chatbot

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
APP_NAME=SUBU Mevzuat Chatbot
APP_VERSION=1.0.0
DEBUG=True

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Scraper Settings
QDMS_URL=https://hukuk.subu.edu.tr/yonergeler
DOWNLOAD_DIRECTORY=./data/raw_pdfs
ARCHIVE_DIRECTORY=./data/archive
JSON_DIRECTORY=./data/processed_json

# Scheduler Settings (in hours)
UPDATE_INTERVAL=24

# LLM Settings
MODEL_NAME=gpt-3.5-turbo
TEMPERATURE=0.1
MAX_TOKENS=1000

# Embedding Settings
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=800
CHUNK_OVERLAP=150
