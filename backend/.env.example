# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/subu_chatbot

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
APP_NAME=SUBU Mevzuat Chatbot
APP_VERSION=1.0.0
DEBUG=True

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Scraper Settings
QDMS_URL=https://hukuk.subu.edu.tr/yonergeler
DOWNLOAD_DIRECTORY=./data/raw_pdfs
ARCHIVE_DIRECTORY=./data/archive
JSON_DIRECTORY=./data/processed_json

# Scheduler Settings (in hours)
UPDATE_INTERVAL=24

# LLM Settings
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.1
MAX_TOKENS=1200

# ---- Ubuntu sunucu: Qwen 14B (Ollama) ----
# 1. Sunucuda: curl -fsSL https://ollama.com/install.sh | sh
# 2. ollama pull qwen2.5:14b
# 3. ollama pull bge-m3
# 4. Aşağıdaki değişkenleri ayarla:
# LLM_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=qwen2.5:14b
# MAX_TOKENS=2000
# EMBEDDING_MODEL=bge-m3

# Embedding Settings (bge-m3: Ollama yerel, text-embedding-3-small: OpenAI API)
EMBEDDING_MODEL=bge-m3
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# CORS Settings (comma-separated origins)
# Development: http://localhost:3000
# Production: Add your domain, e.g., https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Cache Settings (Optional - Redis)
REDIS_ENABLED=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
QUERY_CACHE_TTL=3600
RESPONSE_CACHE_TTL=1800
